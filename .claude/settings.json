{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/verify-on-change.py",
            "shell": "bash",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
