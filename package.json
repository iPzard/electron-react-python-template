{
  "author": "Daniel Wade",
  "description": "Starter template for Electron, React, Python app",
  "dependencies": {
    "@reduxjs/toolkit": "2.11.2",
    "get-port": "5.1.1",
    "prop-types": "15.8.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-redux": "9.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@babel/eslint-parser": "7.28.6",
    "cross-env": "7.0.3",
    "electron": "30.0.0",
    "electron-devtools-installer": "3.2.0",
    "electron-installer-dmg": "3.0.0",
    "electron-packager": "17.1.2",
    "electron-wix-msi": "3.0.4",
    "eslint": "8.57.1",
    "levenary": "1.1.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdoc": "4.0.5",
    "sass": "1.99.0"
  },
  "optionalDependencies": {
    "electron-installer-debian": "3.2.0"
  },
  "resolutions": {
    "@babel/preset-env": "7.29.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "extraResources": [
      "./resources/app"
    ]
  },
  "homepage": "./",
  "license": "MIT",
  "main": "main.js",
  "name": "electron-react-python-template",
  "private": true,
  "scripts": {
    "build": "node ./scripts/dispatch build all",
    "build:all": "node ./scripts/dispatch build all",
    "build:react": "node ./scripts/dispatch build react",
    "build:python": "node ./scripts/dispatch build python",
    "build:docs": "jsdoc -c jsdoc.json",
    "build:package:linux": "node ./scripts/dispatch package linux",
    "build:package:mac": "node ./scripts/dispatch package mac",
    "build:package:windows": "node ./scripts/dispatch package windows",
    "clean": "node ./scripts/dispatch clean",
    "clean:all": "node ./scripts/dispatch clean all",
    "eject": "react-scripts eject",
    "lint": "eslint src --ext .js,.jsx",
    "start": "node ./scripts/dispatch start",
    "start:electron": "electron .",
    "start:react": "cross-env DISABLE_ESLINT_PLUGIN=true react-scripts start",
    "test": "react-scripts test",
    "test:python": "python -m pytest",
    "verify": "yarn lint && yarn test --watchAll=false && yarn test:python && yarn build:react"
  },
  "version": "1.0.0"
}
