{
  "author": "Daniel Wade",
  "description": "Starter template for Electron, React, Python app",
  "dependencies": {
    "@reduxjs/toolkit": "2.11.2",
    "get-port": "5.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-redux": "9.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "29.5.13",
    "@types/node": "20.16.13",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "8.13.0",
    "@typescript-eslint/parser": "8.13.0",
    "cross-env": "7.0.3",
    "electron": "30.0.0",
    "electron-devtools-installer": "3.2.0",
    "electron-installer-dmg": "3.0.0",
    "electron-packager": "17.1.2",
    "electron-wix-msi": "3.0.4",
    "eslint": "8.57.1",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "18.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "jsdoc": "4.0.5",
    "levenary": "1.1.1",
    "sass": "1.99.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "optionalDependencies": {
    "electron-installer-debian": "3.2.0"
  },
  "resolutions": {
    "@babel/preset-env": "7.29.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "extraResources": [
      "./resources/app"
    ]
  },
  "homepage": "./",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "name": "electron-react-python-template",
  "private": true,
  "scripts": {
    "build": "tsx ./scripts/dispatch.ts build all",
    "build:all": "tsx ./scripts/dispatch.ts build all",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:react": "tsx ./scripts/dispatch.ts build react",
    "build:python": "tsx ./scripts/dispatch.ts build python",
    "build:docs": "jsdoc -c jsdoc.json",
    "build:package:linux": "tsx ./scripts/dispatch.ts package linux",
    "build:package:mac": "tsx ./scripts/dispatch.ts package mac",
    "build:package:windows": "tsx ./scripts/dispatch.ts package windows",
    "clean": "tsx ./scripts/dispatch.ts clean",
    "clean:all": "tsx ./scripts/dispatch.ts clean all",
    "eject": "react-scripts eject",
    "lint": "eslint src scripts main.ts preload.ts --ext .js,.jsx,.ts,.tsx",
    "start": "tsx ./scripts/dispatch.ts start",
    "start:electron": "electron .",
    "start:react": "cross-env DISABLE_ESLINT_PLUGIN=true react-scripts start",
    "test": "react-scripts test",
    "test:python": "python -m pytest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json && tsc --noEmit -p tsconfig.scripts.json",
    "verify": "yarn lint && yarn typecheck && yarn test --watchAll=false && yarn test:python && yarn build:react"
  },
  "version": "1.0.0"
}
